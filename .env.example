# DM backend: anthropic (default) or openclaw (OpenClaw Gateway POST /v1/responses — enable in openclaw.json)
# DM_PROVIDER=anthropic

# --- When DM_PROVIDER=anthropic (or unset) ---
# Anthropic Messages API (official Claude), or any Anthropic-compatible proxy (e.g. MiMo):
# ANTHROPIC_BASE_URL=https://api.mimo-v2.com/anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- When DM_PROVIDER=openclaw ---
# OPENCLAW_BASE_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=gateway-token-from-openclaw-config
# OPENCLAW_MODEL=openclaw/default
# Optional: OPENCLAW_AGENT_ID=main   OPENCLAW_BACKEND_MODEL=anthropic/claude-sonnet-4-6
# ANTHROPIC_API_KEY not required in openclaw mode

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_id_here
DISCORD_GUILD_ID=your_discord_server_id_here

# Web Server
WEB_PORT=3000
WEB_SECRET=change_this_to_random_secret

# Database
DATABASE_PATH=./dnd.db

# Default language: 'th' (Thai) or 'en' (English)
DEFAULT_LANGUAGE=th

# Model: Claude id (e.g. claude-opus-4-7) or MiMo id from dashboard (often mimo-v2-pro)
# DM_MODEL=claude-opus-4-7
DM_MODEL=mimo-v2-pro

# Channel ID where DM narrates (optional - if empty, uses any channel where /dm is used)
DM_CHANNEL_ID=
